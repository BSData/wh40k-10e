        <profile name="Psychological Saboteur (Aura)" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities" hidden="false" id="f420-4c72-dafd-6998">
          <characteristics>
            <characteristic name="Description" typeId="9b8f-694b-e5e-b573">While an enemy unit is with 12&quot; of this model, if that unit is Battle-shocked:

- Each time a model in that unit makes an attack, subtract 1 from the Hit roll
- Each time a friendly TYRANIDS model makes an attack that targets that unit, add 1 to the Wound roll.</characteristic>
          </characteristics>
        </profile>
