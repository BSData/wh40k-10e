            <selectionEntry type="upgrade" import="true" name="Master Saboteur" hidden="false" id="f793-7dfa-d20a-7410">
              <profiles>
                <profile name="Master Saboteur" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities" hidden="false" id="32ed-89d5-c7bb-268c">
                  <characteristics>
                    <characteristic name="Description" typeId="9b8f-694b-e5e-b573">The first time in the battle that your opponent&apos;s army Secures an objective marker while the bearer is on the battlefield, roll one D6: on a 3+, that objective marker is not Secured by your opponent&apos;s army.</characteristic>
                  </characteristics>
                </profile>
