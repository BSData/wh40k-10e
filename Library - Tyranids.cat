                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
          </modifiers>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Neural Dissonance" hidden="false" id="deb0-1b51-6ada-da39">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="fd4b-716b-dbfc-4c76" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="Neural Dissonance" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities" hidden="false" id="5950-ef0f-3adf-1afc">
              <characteristics>
                <characteristic name="Description" typeId="9b8f-694b-e5e-b573">This unit cannot benefit from Stratagems or Detachment Rules that require the **^^Synapse^^** keyword.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
