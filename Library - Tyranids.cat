              <profiles>
                <profile id="c664-fd7d-1b66-2780" name="Instinctive Defense" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
                  <characteristics>
                    <characteristic name="Description" typeId="9b8f-694b-e5e-b573">**^^Tyranids^^** model only. While the bearer is within 6&quot; of one or more **^^Harvester^^** units, you can target the bearer&apos;s unit with the Heroic Intervention Stratagem for 0CP. In addition, while the bearer is within 6&quot; of one or more friendly **^^Harvester^^** units, models in the bearer&apos;s unit have the Fights First ability.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="pts" typeId="51b2-306e-1021-d207" value="15"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="9785-ca88-1ecd-2d55" name="Parasitic Biomorphology" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="set" field="hidden" value="true">
                  <conditions>
                    <condition field="selections" scope="ancestor" value="1" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="d1d8-6ae0-1be7-e9e" type="notInstanceOf"/>
                  </conditions>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b051-7c22-14eb-c85d" type="max"/>
                <constraint field="selections" scope="roster" value="1" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="aa15-16fb-2417-ba7" type="max"/>
              </constraints>
              <profiles>
                <profile id="68ef-4d8f-7fc-994f" name="Parasitic Biomorphology" hidden="false" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities">
                  <characteristics>
                    <characteristic name="Description" typeId="9b8f-694b-e5e-b573">**^^Tyranids^^** model only. Add 1 to the Strength characteristic of melee weapons equipped by models in the bearer&apos;s unit. The first time the bearer&apos;s unit destroys an enemy unit in the Fight phase while the bearer is within 6&quot; of one or more **^^Harvester^^** units, until the end of battle, add 1 to the Attacks characteristic of melee weapons equipped by models in the bearer&apos;s unit.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="pts" typeId="51b2-306e-1021-d207" value="25"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="9531-2e9e-5137-baff" name="Regenerating Monstrosity" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="set" field="hidden" value="true">
                  <conditionGroups>
                    <conditionGroup type="or">
