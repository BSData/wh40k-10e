        <selectionEntry type="upgrade" import="true" name="Casts No Shadow" hidden="false" id="9b1e-095e-fa33-228e">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="07c6-f045-a97b-94a5" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="Casts No Shadow" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities" hidden="false" id="ceee-55f8-0cee-b05a">
              <characteristics>
                <characteristic name="Description" typeId="9b8f-694b-e5e-b573">While this unit has this Battle Scar, it is affected by your army&apos;s Shadow in the Warp ability (and thus must take a Battle-shock test when it is used).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="51b2-306e-1021-d207" value="0"/>
            <cost name="Crusade Points" typeId="b03b-c239-15a5-da55" value="-1"/>
