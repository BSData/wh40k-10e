              <conditionGroups>
                <conditionGroup type="and">
                  <conditions>
                    <condition type="notInstanceOf" value="1" field="selections" scope="ancestor" childId="4129-a453-686a-d38a" shared="true" includeChildSelections="false" includeChildForces="false"/>
                    <condition type="lessThan" value="1" field="selections" scope="root-entry" childId="4129-a453-686a-d38a" shared="true" includeChildSelections="true" includeChildForces="false"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
          </modifiers>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Synaptic Decay" hidden="false" id="b449-fdd3-7412-c943">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="3503-5d64-c75a-9b26" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="Synaptic Decay" typeId="9cc3-6d83-4dd3-9b64" typeName="Abilities" hidden="false" id="8cff-cb8e-96bf-181f">
              <characteristics>
                <characteristic name="Description" typeId="9b8f-694b-e5e-b573">Reduce the range of this model&apos;s Synapse ability to 3&quot;.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
